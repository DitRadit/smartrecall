# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database (Prisma + SQLite default, lihat ARCHITECTURE.md bagian 7) ---
# Untuk production, gunakan PostgreSQL: postgresql://user:password@localhost:5432/smartrecall
DATABASE_URL="file:./database/dev.db"

# --- Auth ---
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ganti_dengan_secret_yang_kuat_di_produksi
JWT_EXPIRES_IN=7d

# --- AI Service (HANYA backend-api yang boleh memanggil ini langsung) ---
# Tidak boleh di-expose ke frontend (lihat ARCHITECTURE.md bagian 6)
AI_SERVICE_URL=http://localhost:5001
AI_SERVICE_TIMEOUT_MS=180000

# --- CORS ---
# URL frontend yang diizinkan untuk mengakses API ini
FRONTEND_ORIGIN=http://localhost:5173
