# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database (Prisma + SQLite default, lihat ARCHITECTURE.md bagian 7) ---
DATABASE_URL="file:./database/dev.db"

# --- Auth ---
JWT_SECRET=ganti_dengan_secret_yang_kuat_di_produksi
JWT_EXPIRES_IN=7d

# --- ai-service (HANYA backend-api yang boleh memanggil ini langsung) ---
AI_SERVICE_URL=http://localhost:5001
AI_SERVICE_TIMEOUT_MS=180000

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173
