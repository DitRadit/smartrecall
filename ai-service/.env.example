# =============================================================================
# PENTING: File ini adalah TEMPLATE. Copy jadi .env, lalu isi value asli di sana.
# JANGAN PERNAH commit .env (isi asli) ke git atau paste ke chat/tempat publik.
# Kalau API key pernah ke-share/ke-expose, SEGERA rotate/revoke lewat dashboard
# provider terkait sebelum dipakai lagi.
# =============================================================================

# --- Provider default (dipakai kalau AI_PROVIDER_<JENIS> di bawah tidak di-set) ---
AI_PROVIDER=nvidia

# --- NVIDIA NIM ---
NIM_API_KEY=your_nvidia_nim_api_key_here
NIM_API_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL_NAME=meta/llama-3.1-8b-instruct
NIM_REQUEST_TIMEOUT_SECONDS=60
NIM_MAX_RETRIES=4
NIM_RATE_LIMIT_SLEEP_SECONDS=30

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL_NAME=gemini-flash-latest
GEMINI_REQUEST_TIMEOUT_SECONDS=60
GEMINI_MAX_RETRIES=4
GEMINI_RATE_LIMIT_SLEEP_SECONDS=30

# =============================================================================
# TASK-SPLITTING (opsional): tentukan provider & model BERBEDA per jenis konten.
# Kalau baris di bawah ini di-COMMENT/dihapus, otomatis jatuh ke AI_PROVIDER /
# NIM_MODEL_NAME / GEMINI_MODEL_NAME di atas (perilaku default/lama).
#
# Fallback otomatis tetap jalan: kalau provider yang ditugaskan ke suatu jenis
# konten gagal total, sistem otomatis coba provider satunya sebagai cadangan
# -- SELAMA kedua API key (NIM_API_KEY & GEMINI_API_KEY) di atas terisi.
# =============================================================================

# Provider per jenis konten
AI_PROVIDER_FLASHCARD=nvidia
AI_PROVIDER_RANGKUMAN=nvidia
AI_PROVIDER_SOAL=nvidia

# Model NVIDIA NIM per jenis konten (contoh: soal pakai Llama 70B yang lebih
# kuat menalar opsi jawaban, flashcard/rangkuman cukup 8B yang cepat & murah)
NIM_MODEL_NAME_FLASHCARD=meta/llama-3.1-8b-instruct
NIM_MODEL_NAME_RANGKUMAN=meta/llama-3.1-8b-instruct
NIM_MODEL_NAME_SOAL=meta/llama-3.1-8b-instruct

# Model Gemini per jenis konten (dipakai kalau NVIDIA gagal & fallback ke Gemini)
GEMINI_MODEL_NAME_FLASHCARD=gemini-flash-latest
GEMINI_MODEL_NAME_RANGKUMAN=gemini-flash-latest
GEMINI_MODEL_NAME_SOAL=gemini-pro-latest

# --- Delay antar-request ---
# Delay between consecutive requests ke AI service (routes/generate.py)
# Catatan: env var ini HARUS bernama AI_INTER_REQUEST_DELAY_SECONDS agar
# dibaca dengan benar oleh routes/generate.py
AI_INTER_REQUEST_DELAY_SECONDS=6

# --- Konfigurasi topup soal (opsional, ada default di kode kalau tidak di-set) ---
# MIN_SOAL_COUNT=10
# MAX_SOAL_TOPUP_ATTEMPTS=2
# SOAL_TOPUP_DELAY_SECONDS=2

# --- Flask / Server ---
FLASK_ENV=development
PORT=5001
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH_MB=20
