# --- NVIDIA NIM API ---
# Ambil API key dari https://build.nvidia.com (free tier tersedia untuk MVP)
# JANGAN commit file .env asli ke git. File ini hanya contoh.
NIM_API_KEY=your_nvidia_nim_api_key_here
NIM_API_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL_NAME=meta/llama-3.1-8b-instruct

# --- Flask app config ---
FLASK_ENV=development
FLASK_APP=app.py
PORT=5001

# --- Upload settings ---
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH_MB=20

# --- Batch generate / retry (dikontrol lebih lanjut di backend-api, ini hanya fallback lokal) ---
NIM_REQUEST_TIMEOUT_SECONDS=60
NIM_MAX_RETRIES=2
