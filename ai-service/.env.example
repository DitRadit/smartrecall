# --- AI provider ---
# Pilihan: "nvidia" atau "gemini"
# JANGAN commit file .env asli ke git. File ini hanya contoh.
AI_PROVIDER=nvidia

# --- NVIDIA NIM API ---
NIM_API_KEY=your_nvidia_nim_api_key_here
NIM_API_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL_NAME=meta/llama-3.1-8b-instruct
NIM_REQUEST_TIMEOUT_SECONDS=60
NIM_MAX_RETRIES=4
NIM_RATE_LIMIT_SLEEP_SECONDS=30

# --- Gemini API (opsional jika AI_PROVIDER=gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL_NAME=gemini-flash-latest

# --- Flask app config ---
FLASK_ENV=development
FLASK_APP=app.py
PORT=5001

# --- Upload settings ---
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH_MB=20

# --- Batch generate / retry Gemini (dipakai jika AI_PROVIDER=gemini) ---
GEMINI_REQUEST_TIMEOUT_SECONDS=60
GEMINI_MAX_RETRIES=4
GEMINI_INTER_REQUEST_DELAY_SECONDS=6
GEMINI_RATE_LIMIT_SLEEP_SECONDS=30
